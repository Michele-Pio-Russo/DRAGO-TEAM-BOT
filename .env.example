DISCORD_TOKEN=your_discord_bot_token
CLIENT_ID=your_client_id
GUILD_ID=your_guild_id

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# In locale va bene ./data/dragobot.db
# Su Railway, se colleghi un Volume, montalo su /data e usa: DB_PATH=/data/dragobot.db
DB_PATH=./data/dragobot.db

INACTIVE_DAYS_DEFAULT=30
INACTIVE_DM_COOLDOWN_DAYS=30
INACTIVE_DM_MESSAGE=Ciao Tenno! DRAGO BOT ha notato che non entri nei canali vocali da un po'. Se vuoi, passa a salutare il clan quando puoi.

# Facoltativo: disattiva la registrazione automatica dei comandi slash ad ogni avvio
# AUTO_DEPLOY_COMMANDS=false

# ─── Avviso automatico inattivi (senza comando manuale) ───────────────────
# Impostare su "true" per attivare l'invio automatico ricorrente.
INACTIVE_AUTO_ENABLED=false
# ID del canale testuale dove pubblicare il riepilogo (tasto destro sul canale
# in Discord con Modalità sviluppatore attiva -> Copia ID canale). Obbligatorio
# se INACTIVE_AUTO_ENABLED=true.
INACTIVE_AUTO_CHANNEL_ID=
# Ogni quanti giorni ripetere l'invio automatico (default 30).
INACTIVE_AUTO_INTERVAL_DAYS=30

# Impostata automaticamente da Railway: NON serve aggiungerla a mano.
# PORT=3000